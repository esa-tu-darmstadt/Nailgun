InstructionSet mac {
  architectural_state {
    unsigned<32> XLEN = 32;
    register unsigned<XLEN> X[32] [[is_main_reg]];
  }

  instructions {
    MAC {
      encoding: 7'd16 :: rs2[4:0] :: rs1[4:0] :: 3'b000 :: rd[4:0] :: 7'b0001011;
      behavior: {
        X[rd] = (unsigned<XLEN>)((signed)X[rs1] * (signed)X[rs2] + (signed)X[rd]);
      }
    }
  }
}
