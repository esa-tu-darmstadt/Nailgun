		config LN_SCHED_ALGO_PA
			depends on LN_SCHED_ALGO_MS
			bool "Predicate-aware"
			default n
		config LN_SCHED_ALGO_RA
			depends on LN_SCHED_ALGO_MS
			bool "Resource-aware"
			default n
		config LN_SCHED_ALGO_MI
