	config LN_MAX_LOOP_UNROLL_FACTOR
		int "Longnail max loop unroll factor"
		default 16
	config LN_SCHEDULE_TIMEOUT
		int "Longnail scheduling timeout in seconds"
		default 10
	config LN_REFINE_TIMEOUT
		int "Longnail schedule refinement timeout in seconds"
		default 10
	config LN_USE_COMMERCIAL_SOLVER
		bool "Longnail use Gurobi's ILP solver"
		default y
