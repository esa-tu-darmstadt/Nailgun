config SIM_ENABLE
	bool "Run simulation"
	default n

menu "Simulation configuration"
	depends on SIM_ENABLE
	config SIM_TB_PATH
		string "Simulation test program path"
	config SIM_TB_EXPECTED_PATH
		string "Expected simulation output"
	config SIM_TB_COMPILE_FLAGS
		string "Additional TB compile flags"
	config SIM_TB_DISASSEMBLE_ELF
		bool "Create a disassembly file of the TB"
		default y
	config SIM_CYCLE_TIMEOUT
		string "Cycle limit"
		default "1000000"
	config SIM_CLK_PERIOD
		string "Simulated clock period (ps)"
		default "1000"
		help
		  Drives the cocotb Clock(...) toggle rate via the +CLK_PERIOD plusarg
		  read by sim/test_default.py. Set to match the synthesis target when
		  running GLS (e.g. 2000 for 500 MHz).
	menu "Lock-step"
		depends on CORE_CVA5 || CORE_CVA6 || CORE_CVA6_DUAL
		config SIM_ENABLE_ISS_LOCKSTEP
			bool "Enable ISS lock-step comparison"
			default n
		config SIM_ISS_RENODE_OVERRIDE_ENABLED
			depends on SIM_ENABLE_ISS_LOCKSTEP
			bool "Override the ISAX python model path"
			default n
		config SIM_ISS_RENODE_OVERRIDE
			depends on SIM_ISS_RENODE_OVERRIDE_ENABLED
			string "ISAX python model path (override)"
			default ""
		config SIM_ISS_PREDEFINED_ISAXES
			depends on SIM_ENABLE_ISS_LOCKSTEP
			string "Predefined ISAX handlers to select (comma-separated list)"
			default ""
	endmenu
	menu "Verbosity"
		config SIM_PRINT_CLK
			bool "Print CLK"
			default y
		config SIM_PRINT_IMEM
			bool "Print IMEM transactions"
			default y
		config SIM_PRINT_DMEM
			bool "Print DMEM transactions"
			default y
		config SIM_PRINT_BRAM
			bool "Print BRAM transactions"
			default y
		config SIM_PRINT_AXI
			bool "Print AXI transactions"
			default y
		config SIM_PRINT_ISS
			bool "Print ISS trace output"
			default y
	endmenu
endmenu
