config SIM_ENABLE
	bool "Run simulation"
	default n

menu "Simulation configuration"
	depends on SIM_ENABLE
	config SIM_TB_PATH
		string "Simulation test program path"
	config SIM_TB_EXPECTED_PATH
		string "Expected simulation output"
	config SIM_TB_COMPILE_FLAGS
		string "Additional TB compile flags"
	config SIM_TB_DISASSEMBLE_ELF
		bool "Create a disassembly file of the TB"
		default y
	config SIM_CYCLE_TIMEOUT
		string "Cycle limit"
		default "1000000"
	menu "Verbosity"
		config SIM_PRINT_CLK
			bool "Print CLK"
			default y
		config SIM_PRINT_IMEM
			bool "Print IMEM transactions"
			default y
		config SIM_PRINT_DMEM
			bool "Print DMEM transactions"
			default y
		config SIM_PRINT_BRAM
			bool "Print BRAM transactions"
			default y
		config SIM_PRINT_AXI
			bool "Print AXI transactions"
			default y
	endmenu
endmenu
