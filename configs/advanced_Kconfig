menu "Advanced Options"
	config SCAIEV_DO_NOT_REBUILD
		bool "Build SCAIE-V only once"
		default n
	config ONLY_PATCH_CC
		bool "ONLY run HLS and add compiler support for the ISAXes"
		default n
	config SIM_SKIP_CC
		depends on SIM_ENABLE
		bool "Skip patching and rebuilding clang"
		default n
	config SIM_LLVM_VERSION
		depends on SIM_ENABLE || ONLY_PATCH_CC
		string "LLVM / clang version to use"
		default "21"
	config SIM_LLVM_OVERWRITE_ISAX_NAME
		depends on SIM_ENABLE
		bool "Overwrite the clang ISAX extension name"
		default n
	config SIM_LLVM_ISAX_NAME
		depends on SIM_LLVM_OVERWRITE_ISAX_NAME
		string "ISAX name"
		default "merged"
	config USE_DYNAMIC_ISAX
		depends on SIM_ENABLE || ONLY_PATCH_CC
		bool "Use dynamic ISAX LLVM (no patching/rebuilding required)"
		default n

	choice
		prompt "Alternate Entrypoint"
		default DEFAULT_ENTRY_POINT

		config DEFAULT_ENTRY_POINT
			bool "None"

		config NO_ISAX_ENTRY_POINT
			bool "No ISAX"

		config COREDSL_MLIR_ENTRY_POINT
			bool "Use a CoreDSL MLIR file as entrypoint"
		config PREPARED_MLIR_ENTRY_POINT
			bool "Use a for scheduling prepared MLIR file as entrypoint"
		config SOLUTION_MLIR_ENTRY_POINT
			bool "Use a MLIR file containing the scheduling solutions as entrypoint"

		config SV_ENTRY_POINT
			bool "Use (System-)Verilog ISAX as entrypoint"
	endchoice

	config MLIR_ENTRY_POINT_PATH
		depends on COREDSL_MLIR_ENTRY_POINT || PREPARED_MLIR_ENTRY_POINT || SOLUTION_MLIR_ENTRY_POINT
		string "Path to mlir file"

	menu "SV entrypoint settings"
		depends on SV_ENTRY_POINT
		config SV_ENTRY_POINT_PATH
			string "Path to SV file"
		config SV_ENTRY_POINT_ISAX_YAML_PATH
			string "Path to ISAX YAML file"
	endmenu

	config USE_PREBUILT_LN
		bool "Use prebuilt Longnail binaries"
		default n
	menu "Longnail prebuilt settings"
		depends on USE_PREBUILT_LN
		config LN_BINARY
			string "Path to Longnail binary"
			default "deps/longnail/build/bin/longnail-opt"
	endmenu

	config USE_PREBUILT_LLVM_PATCHER
		bool "Use prebuilt LLVM patcher binaries"
		default n
	menu "LLVM patcher prebuilt settings"
		depends on USE_PREBUILT_LLVM_PATCHER
		config LLVM_PATCHER_BINARY
			string "Path to LLVM patcher binary"
			default "deps/llvm_patcher/build/bin/llvm-patcher-opt"
	endmenu

endmenu
